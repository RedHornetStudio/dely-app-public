{
  "expo": {
    "name": "Dely",
    "slug": "Dely",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/dely-icon.png",
    "splash": {
      "image": "./assets/dely-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#171717"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/dely-adaptive-icon.png",
        "backgroundColor": "#9d2235"
      },
      "package": "com.redhornetstudio.dely",
      "softwareKeyboardLayoutMode": "pan"
    },
    "androidStatusBar": {
      "barStyle": "light-content",
      "backgroundColor": "#00000000",
      "translucent": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
